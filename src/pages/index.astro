---
// src/pages/index.astro
const TURNOS_URL = "https://devhub-turnos.vercel.app/reservar/santos-detailing";
const IG_URL = "https://www.instagram.com/santos.detailing_cat/";
const WA_NUM = "5493834222905";

const servicios = [
  {
    id: "lavado-basico",
    nombre: "Lavado Básico",
    precio: "$8.000",
    duracion: "1 hora",
    descripcion: "Limpieza exterior e interior completa a mano.",
    items: [
      "Lavado exterior a mano",
      "Aspirado interior completo",
      "Limpieza de vidrios",
      "Limpieza de tablero",
      "Aromatización",
    ],
    destacado: false,
  },
  {
    id: "detailing-pro",
    nombre: "Detailing Pro",
    precio: "$25.000",
    duracion: "3-4 horas",
    descripcion: "Restauración profunda de pintura y habitáculo.",
    items: [
      "Todo lo del Básico",
      "Pulido de pintura",
      "Descontaminación ferrosa",
      "Limpieza de llantas y neumáticos",
      "Tratamiento de plásticos interiores",
      "Encerado protector",
    ],
    destacado: true,
  },
  {
    id: "ceramica-premium",
    nombre: "Cerámica Premium",
    precio: "$55.000",
    duracion: "6-8 horas",
    descripcion: "Protección cerámica profesional de larga duración.",
    items: [
      "Todo lo del Pro",
      "Corrección de pintura",
      "Aplicación de coating cerámico",
      "Protección de vidrios",
      "Ozono interior",
      "Garantía 12 meses",
    ],
    destacado: false,
  },
];

const productos = [
  {
    nombre: "Cherry Quick",
    desc: "Quick detailer con aroma a cereza. Brillo instantáneo entre lavados.",
    img: "https://static.toxicshine.com.ar/prod/2024/10/Cherry-Quick-768x1149.jpg",
  },
  {
    nombre: "Illusion Wax",
    desc: "Cera de carnauba premium. Protección y brillo de larga duración.",
    img: "https://static.toxicshine.com.ar/prod/2024/10/Ilussion-Wax-768x1149.jpg",
  },
  {
    nombre: "Shampoo Banana",
    desc: "Shampoo pH neutro con aroma a banana. Limpieza suave y segura.",
    img: "https://static.toxicshine.com.ar/prod/2025/02/Shampoo-Banana-768x1149.jpg",
  },
  {
    nombre: "Iron Warning",
    desc: "Descontaminante ferroso. Elimina el polvo de freno eficazmente.",
    img: "https://static.toxicshine.com.ar/prod/2025/02/Iron-Warning-768x1149.jpg",
  },
  {
    nombre: "Hyper Black",
    desc: "Restaurador de plásticos negros. Deja un acabado profundo y duradero.",
    img: "https://static.toxicshine.com.ar/prod/2025/02/Hyper-Black-768x1149.jpg",
  },
  {
    nombre: "Seal It All",
    desc: "Sellador universal de pintura. Protección máxima con alto brillo.",
    img: "https://static.toxicshine.com.ar/prod/2025/02/Seal-It-All-768x1149.jpg",
  },
];
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Santos Detailing Catamarca — Servicio profesional de detailing y cerámica automotriz. Reservá tu turno online." />
  <meta property="og:title" content="Santos Detailing — Catamarca" />
  <meta property="og:description" content="Protección cerámica y detailing profesional en Catamarca." />
  <title>Santos Detailing — Catamarca</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;500;600;700&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet" />
</head>

<body>

<!-- ══ NAV ══════════════════════════════════════════════════ -->
<nav id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <div class="logo-icon">S</div>
      <div class="logo-text">
        <span class="logo-main">SANTOS</span>
        <span class="logo-sub">DETAILING</span>
      </div>
    </a>
    <div class="nav-links">
      <a href="#servicios">Servicios</a>
      <a href="#productos">Productos</a>
      <a href="#proceso">Proceso</a>
      <a href="#galeria">Galería</a>
      <a href="#contacto">Contacto</a>
      <a href={TURNOS_URL} class="nav-cta" target="_blank">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Reservar turno
      </a>
    </div>
    <button class="nav-hamburger" id="hamburger" aria-label="Menú">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobileMenu">
  <a href="#servicios" class="mobile-link">Servicios</a>
  <a href="#productos" class="mobile-link">Productos</a>
  <a href="#proceso" class="mobile-link">Proceso</a>
  <a href="#galeria" class="mobile-link">Galería</a>
  <a href="#contacto" class="mobile-link">Contacto</a>
  <a href={TURNOS_URL} class="mobile-cta" target="_blank">Reservar turno</a>
</div>

<!-- ══ HERO ═════════════════════════════════════════════════ -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-lines">
      <div class="line"></div>
      <div class="line"></div>
      <div class="line"></div>
    </div>
  </div>

  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="eyebrow-dot"></span>
      <span>Catamarca, Argentina</span>
      <span class="eyebrow-sep">·</span>
      <span>Detailing Profesional</span>
    </div>

    <h1 class="hero-title">
      <span class="title-line">SANTOS</span>
      <span class="title-line title-outline">DETAILING</span>
    </h1>

    <p class="hero-desc">
      Cerámica profesional, pulido de pintura y detailing completo.<br/>
      Tu auto merece el mejor tratamiento.
    </p>

    <div class="hero-actions">
      <a href={TURNOS_URL} class="btn-primary" target="_blank">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Reservar turno ahora
      </a>
      <a href="#servicios" class="btn-outline">Ver servicios</a>
    </div>

    <div class="hero-badges">
      <div class="badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Productos premium
      </div>
      <div class="badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Garantía en cada trabajo
      </div>
      <div class="badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Turnos online 24/7
      </div>
    </div>
  </div>

  <div class="hero-scroll-indicator">
    <div class="scroll-bar"></div>
  </div>
</section>

<!-- ══ STATS ════════════════════════════════════════════════ -->
<section class="stats">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item">
        <span class="stat-num">500<span class="stat-plus">+</span></span>
        <span class="stat-label">Autos detallados</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-num">5<span class="stat-star">★</span></span>
        <span class="stat-label">Calificación promedio</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-num">3<span class="stat-plus">+</span></span>
        <span class="stat-label">Años de experiencia</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-num">100<span class="stat-pct">%</span></span>
        <span class="stat-label">Satisfacción garantizada</span>
      </div>
    </div>
  </div>
</section>

<!-- ══ SERVICIOS ════════════════════════════════════════════ -->
<section id="servicios" class="servicios">
  <div class="container">
    <div class="section-header">
      <div class="section-tag">
        <span class="tag-line"></span>
        Nuestros servicios
        <span class="tag-line"></span>
      </div>
      <h2 class="section-title">ELEGÍ TU <span class="title-red">TRATAMIENTO</span></h2>
      <p class="section-desc">Cada servicio está diseñado para proteger y realzar tu vehículo con los mejores productos del mercado.</p>
    </div>

    <div class="servicios-grid">
      {servicios.map((s, i) => (
        <div class={`servicio-card ${s.destacado ? "card-destacado" : ""}`}>
          {s.destacado && <div class="card-popular">MÁS POPULAR</div>}
          <div class="card-num">0{i + 1}</div>
          <div class="card-body">
            <h3 class="card-titulo">{s.nombre}</h3>
            <div class="card-meta">
              <span class="card-duracion">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                {s.duracion}
              </span>
            </div>
            <p class="card-desc">{s.descripcion}</p>
            <ul class="card-lista">
              {s.items.map(item => (
                <li>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="card-footer">
            <div class="card-precio">
              <span class="precio-desde">desde</span>
              <span class="precio-val">{s.precio}</span>
            </div>
            <a href={`${TURNOS_URL}?servicio=${s.id}`} class="card-btn" target="_blank">
              Reservar
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══ PRODUCTOS ════════════════════════════════════════════ -->
<section id="productos" class="productos">
  <div class="container">
    <div class="section-header">
      <div class="section-tag">
        <span class="tag-line"></span>
        Tienda
        <span class="tag-line"></span>
      </div>
      <h2 class="section-title">PRODUCTOS <span class="title-red">PREMIUM</span></h2>
      <p class="section-desc">Los mismos productos que usamos en cada trabajo. Disponibles para que cuides tu auto en casa.</p>
    </div>

    <div class="productos-grid">
      {productos.map(p => (
        <div class="producto-card">
          <div class="producto-img-wrap">
            <img src={p.img} alt={p.nombre} class="producto-img" />
          </div>
          <div class="producto-info">
            <h3 class="producto-nombre">{p.nombre}</h3>
            <p class="producto-desc">{p.desc}</p>
          </div>
          <div class="producto-footer">
            <span class="producto-badge">Toxic Shine®</span>
            <a
              href={`https://wa.me/${WA_NUM}?text=Hola%20Santos%20Detailing!%20Quiero%20consultar%20por%20${encodeURIComponent(p.nombre)}`}
              target="_blank"
              class="producto-cta"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.856L.054 23.285a.75.75 0 0 0 .921.921l5.43-1.478A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.693-.503-5.235-1.382l-.374-.217-3.876 1.054 1.054-3.876-.217-.374A9.953 9.953 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
              </svg>
              Consultar
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══ PROCESO ═══════════════════════════════════════════════ -->
<section id="proceso" class="proceso">
  <div class="container">
    <div class="proceso-inner">
      <div class="proceso-text">
        <div class="section-tag left">
          <span class="tag-line"></span>
          ¿Cómo funciona?
        </div>
        <h2 class="section-title">ASÍ DE <span class="title-red">SIMPLE</span></h2>
        <p class="section-desc">Reservar tu turno es rápido y fácil. Sin llamadas, sin esperas.</p>
      </div>

      <div class="pasos">
        <div class="paso">
          <div class="paso-num">01</div>
          <div class="paso-content">
            <h3>Elegís el servicio</h3>
            <p>Seleccionás el tratamiento que necesita tu auto según tu presupuesto y necesidades.</p>
          </div>
        </div>
        <div class="paso-conector"></div>
        <div class="paso">
          <div class="paso-num">02</div>
          <div class="paso-content">
            <h3>Reservás el turno</h3>
            <p>Elegís el día y horario que mejor te quede. Todo online, en segundos.</p>
          </div>
        </div>
        <div class="paso-conector"></div>
        <div class="paso">
          <div class="paso-num">03</div>
          <div class="paso-content">
            <h3>Retirás impecable</h3>
            <p>Llevás tu auto y nosotros hacemos el resto. Resultado garantizado.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ GALERÍA ═══════════════════════════════════════════════ -->
<section id="galeria" class="galeria">
  <div class="container">
    <div class="section-header">
      <div class="section-tag">
        <span class="tag-line"></span>
        Nuestros trabajos
        <span class="tag-line"></span>
      </div>
      <h2 class="section-title">RESULTADOS <span class="title-red">REALES</span></h2>
    </div>

    <div class="galeria-grid">
      <div class="galeria-item">
        <img src="/1.jpg" alt="Trabajo destacado" />
      </div>
      <div class="galeria-item">
        <img src="/2.jpg" alt="Pulido de pintura" />
      </div>
      <div class="galeria-item">
        <img src="/3.jpg" alt="Cerámica aplicada" />
      </div>
      <div class="galeria-item">
        <img src="/4.jpg" alt="Detailing interior" />
      </div>
      <div class="galeria-item">
        <img src="/5.jpg" alt="Antes / Después" />
      </div>
    </div>

    <div class="galeria-cta">
      <a href={IG_URL} target="_blank" rel="noopener noreferrer" class="ig-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="2" width="20" height="20" rx="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        Ver más trabajos en Instagram
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- ══ CTA CENTRAL ═══════════════════════════════════════════ -->
<section class="cta-band">
  <div class="cta-band-bg"></div>
  <div class="container cta-band-inner">
    <div class="cta-band-text">
      <h2 class="cta-band-title">¿TU AUTO NECESITA <span class="title-red">ATENCIÓN</span>?</h2>
      <p>Reservá tu turno ahora y dale a tu vehículo el tratamiento que merece.</p>
    </div>
    <a href={TURNOS_URL} class="btn-primary btn-lg" target="_blank">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="4" width="18" height="18" rx="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      Reservar turno online
    </a>
  </div>
</section>

<!-- ══ CONTACTO ══════════════════════════════════════════════ -->
<section id="contacto" class="contacto">
  <div class="container">
    <div class="contacto-grid">
      <div class="contacto-info">
        <div class="section-tag left">
          <span class="tag-line"></span>
          Contacto
        </div>
        <h2 class="section-title">ENCONTRANOS<br/><span class="title-red">EN CATAMARCA</span></h2>
        <div class="contacto-items">
          <div class="contacto-item">
            <div class="contacto-ico">📍</div>
            <div>
              <p class="ci-label">Ubicación</p>
              <p class="ci-val">Catamarca, Argentina</p>
            </div>
          </div>
          <div class="contacto-item">
            <div class="contacto-ico">📱</div>
            <div>
              <p class="ci-label">WhatsApp</p>
              <a href={`https://wa.me/${WA_NUM}`} class="ci-val ci-link">Escribinos</a>
            </div>
          </div>
          <div class="contacto-item">
            <div class="contacto-ico">📷</div>
            <div>
              <p class="ci-label">Instagram</p>
              <a href={IG_URL} target="_blank" class="ci-val ci-link">@santos.detailing_cat</a>
            </div>
          </div>
          <div class="contacto-item">
            <div class="contacto-ico">🕐</div>
            <div>
              <p class="ci-label">Horario de atención</p>
              <p class="ci-val">Lunes a Sábado · 9:00 — 20:00</p>
            </div>
          </div>
        </div>
      </div>

      <div class="contacto-card">
        <div class="cc-header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          <h3>¿Tenés dudas?</h3>
        </div>
        <p>Consultanos por WhatsApp y te respondemos en minutos. También podés reservar tu turno directamente online.</p>
        <div class="cc-btns">
          <a href={`https://wa.me/${WA_NUM}?text=Hola%20Santos%20Detailing!%20Quiero%20consultar%20sobre%20sus%20servicios.`} target="_blank" class="btn-wa">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.856L.054 23.285a.75.75 0 0 0 .921.921l5.43-1.478A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.693-.503-5.235-1.382l-.374-.217-3.876 1.054 1.054-3.876-.217-.374A9.953 9.953 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
            Consultar por WhatsApp
          </a>
          <a href={TURNOS_URL} class="btn-primary" target="_blank">Reservar turno</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ FOOTER ════════════════════════════════════════════════ -->
<footer>
  <div class="container footer-inner">
    <a href="/" class="nav-logo">
      <div class="logo-icon">S</div>
